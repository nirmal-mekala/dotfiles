// src/commands/worktree-selection.ts
async function selectWorktreePath(options) {
  if (options.worktrees.length === 0) {
    throw new Error("no orchard worktrees found");
  }
  if (options.requestedName) {
    const matchingWorktree = options.worktrees.find((worktreePath2) => basename2(worktreePath2) === options.requestedName);
    if (!matchingWorktree) {
      throw new Error(`invalid worktree: ${options.requestedName}`);
    }
    return matchingWorktree;
  }
  if (options.currentWorktreePath) {
    return options.currentWorktreePath;
  }
  if (!options.interactive) {
    throw new Error(`orchard ${options.commandName} requires --worktree <name>`);
  }
  const selected = await select({
    message: "Select a worktree",
    options: options.worktrees.map((worktreePath2) => ({
      label: basename2(worktreePath2),
      value: worktreePath2
    }))
  });
  if (isCancel(selected)) {
    throw new Error("worktree selection cancelled");
  }
  return selected;
}

// src/commands/bootstrap.ts
async function runBootstrap(args, options = {}) {
  try {
    const bootstrapArgs = parseWorktreeArgs("bootstrap", args);
    const cwd = options.cwd ?? process.cwd();
    const currentWorktree = findOrchardWorktree(cwd);
    const repositoryRoot = findBootstrapRepositoryRoot(cwd);
    if (!repositoryRoot) {
      return fail("orchard bootstrap must be run from inside an orchard repository");
    }
    const worktreePath2 = await selectWorktreePath({
      commandName: "bootstrap",
      currentWorktreePath: currentWorktree?.worktreePath,
      interactive: options.interactive ?? Boolean(process.stdin.isTTY && process.stdout.isTTY),
      requestedName: bootstrapArgs.worktreeName,
      worktrees: listOrchardWorktreeCandidates(repositoryRoot)
    });
    const paths = orchardPaths(repositoryRoot);
    const log = [
      formatLog("info", `running bootstrap for ${basename3(worktreePath2)}`)
    ];
    const bootstrapResult = await runBootstrapScript(paths.bootstrapScript, worktreePath2);
    if (bootstrapResult.stdout.length > 0) {
      log.push(bootstrapResult.stdout);
    }
    log.push(formatLog("success", `bootstrapped ${worktreePath2}`));
    return ok(log.join(""));
  } catch (error) {
    return fail(error instanceof Error ? error.message : "bootstrap failed");
  }
}
function findBootstrapRepositoryRoot(cwd) {
  return findOrchardWorktree(cwd)?.repositoryRoot ?? findOrchardRepositoryRoot(cwd) ?? findOrchardRepositoryBaseRoot(cwd);
}

