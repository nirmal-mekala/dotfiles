// src/lib/remote.ts
function parseRemoteUrl(remoteUrl) {
  const trimmedUrl = remoteUrl.trim();
  if (trimmedUrl.length === 0) {
    throw new Error("remote URL cannot be empty");
  }
  const parsed = parseHttpsRemote(trimmedUrl) ?? parseSshRemote(trimmedUrl) ?? parseFileRemote(trimmedUrl);
  if (!parsed) {
    throw new Error(`unsupported remote URL: ${remoteUrl}`);
  }
  return parsed;
}
function repositoryScopeDirectory(remote) {
  if (remote.scopeSegments.length === 0) {
    return remote.host;
  }
  return [remote.host, ...remote.scopeSegments].join("_");
}
function parseHttpsRemote(remoteUrl) {
  let url;
  try {
    url = new URL(remoteUrl);
  } catch {
    return;
  }
  if (url.protocol !== "https:") {
    return;
  }
  return parsePathParts(remoteUrl, url.hostname, url.pathname);
}
function parseSshRemote(remoteUrl) {
  const scpLikeMatch = /^(?:[^@:/]+@)?([^:/]+):(.+)$/.exec(remoteUrl);
  if (scpLikeMatch) {
    const [, host, remotePath] = scpLikeMatch;
    if (host && remotePath) {
      return parsePathParts(remoteUrl, host, remotePath);
    }
  }
  let url;
  try {
    url = new URL(remoteUrl);
  } catch {
    return;
  }
  if (url.protocol !== "ssh:") {
    return;
  }
  return parsePathParts(remoteUrl, url.hostname, url.pathname);
}
function parseFileRemote(remoteUrl) {
  let path = remoteUrl;
  if (remoteUrl.startsWith("file://")) {
    let url;
    try {
      url = new URL(remoteUrl);
    } catch {
      return;
    }
    path = url.pathname;
  } else if (!remoteUrl.startsWith("/") && !remoteUrl.startsWith(".")) {
    return;
  }
  const pathSegments = path.replace(/^\/+/, "").split("/").filter((segment) => segment.length > 0);
  const repoIndex = pathSegments.length - 1;
  const hostIndex = findFixtureHostIndex(pathSegments, repoIndex);
  if (hostIndex === undefined) {
    return;
  }
  return parsePathParts(remoteUrl, pathSegments[hostIndex] ?? "", pathSegments.slice(hostIndex + 1).join("/"));
}
function parsePathParts(original, host, remotePath) {
  const pathSegments = remotePath.replace(/^\/+/, "").split("/").filter((segment) => segment.length > 0);
  const rawRepoName = pathSegments.at(-1);
  if (!host || !rawRepoName || pathSegments.length < 2) {
    throw new Error(`remote URL must include host, scope, and repository: ${original}`);
  }
  return {
    original,
    host,
    scopeSegments: pathSegments.slice(0, -1),
    repoName: stripGitSuffix(rawRepoName)
  };
}
function findFixtureHostIndex(pathSegments, repoIndex) {
  for (let index = repoIndex - 1;index >= 0; index -= 1) {
    if (pathSegments[index]?.includes(".")) {
      return index;
    }
  }
  return;
}
function stripGitSuffix(value) {
  return value.endsWith(".git") ? value.slice(0, -4) : value;
}

// src/lib/orchard-paths.ts
var orchardLayout = {
  gitDirectoryName: "_git",
  symlinksDirectoryName: "_symlinks",
  bootstrapScriptName: "wt_bootstrap.sh"
};
function resolveProjectsRoot(homeDirectory = homedir()) {
  return join(homeDirectory, "projects");
}
function repositoryRootPath(remote, projectsRoot = resolveProjectsRoot()) {
  return join(projectsRoot, repositoryScopeDirectory(remote), remote.repoName);
}
function orchardPaths(repositoryRoot) {
  return {
    repositoryRoot,
    gitDirectory: join(repositoryRoot, orchardLayout.gitDirectoryName),
    symlinksDirectory: join(repositoryRoot, orchardLayout.symlinksDirectoryName),
    bootstrapScript: join(repositoryRoot, orchardLayout.bootstrapScriptName)
  };
}
function worktreeName(repoName, branchName) {
  const normalizedBranchName = branchName.replace(/[\\/]+/g, "-");
  if (repoName.length === 0 || normalizedBranchName.length === 0) {
    throw new Error("repo name and branch name are required");
  }
  return `${repoName}_${normalizedBranchName}`;
}
function worktreePath(repositoryRoot, repoName, branchName) {
  return join(repositoryRoot, worktreeName(repoName, branchName));
}
function isOrchardRepositoryRoot(repositoryRoot) {
  const paths = orchardPaths(repositoryRoot);
  return isOrchardRepositoryBaseRoot(repositoryRoot) && isFile(paths.bootstrapScript);
}
function isOrchardRepositoryBaseRoot(repositoryRoot) {
  const paths = orchardPaths(repositoryRoot);
  return isDirectory(paths.repositoryRoot) && isDirectory(paths.gitDirectory) && isDirectory(paths.symlinksDirectory);
}
function findOrchardRepositoryRoot(startDirectory) {
  let currentDirectory = resolve(startDirectory);
  while (true) {
    if (isOrchardRepositoryRoot(currentDirectory)) {
      return currentDirectory;
    }
    const parentDirectory = dirname(currentDirectory);
    if (parentDirectory === currentDirectory) {
      return;
    }
    currentDirectory = parentDirectory;
  }
}
function findOrchardRepositoryBaseRoot(startDirectory) {
  let currentDirectory = resolve(startDirectory);
  while (true) {
    if (isOrchardRepositoryBaseRoot(currentDirectory)) {
      return currentDirectory;
    }
    const parentDirectory = dirname(currentDirectory);
    if (parentDirectory === currentDirectory) {
      return;
    }
    currentDirectory = parentDirectory;
  }
}
function findOrchardWorktree(startDirectory) {
  let currentDirectory = resolve(startDirectory);
  while (true) {
    const parentDirectory = dirname(currentDirectory);
    if (isOrchardRepositoryRoot(parentDirectory) && isWorktreeDirectory(currentDirectory, parentDirectory)) {
      return {
        repositoryRoot: parentDirectory,
        worktreePath: currentDirectory,
        worktreeName: basename(currentDirectory)
      };
    }
    if (parentDirectory === currentDirectory) {
      return;
    }
    currentDirectory = parentDirectory;
  }
}
function worktreeExists(repositoryRoot, repoName, branchName) {
  return isDirectory(worktreePath(repositoryRoot, repoName, branchName));
}
function listOrchardRepositories(projectsRoot) {
  if (!isDirectory(projectsRoot)) {
    return [];
  }
  const repositoryRoots = [];
  for (const scopeEntry of safeReadDirectory(projectsRoot)) {
    if (!scopeEntry.isDirectory()) {
      continue;
    }
    const scopePath = join(projectsRoot, scopeEntry.name);
    for (const repoEntry of safeReadDirectory(scopePath)) {
      if (!repoEntry.isDirectory()) {
        continue;
      }
      const repositoryRoot = join(scopePath, repoEntry.name);
      if (isOrchardRepositoryRoot(repositoryRoot)) {
        repositoryRoots.push(repositoryRoot);
      }
    }
  }
  return repositoryRoots.sort();
}
function listOrchardWorktrees(repositoryRoot) {
  if (!isOrchardRepositoryRoot(repositoryRoot)) {
    return [];
  }
  return listOrchardWorktreeCandidates(repositoryRoot);
}
function listOrchardWorktreeCandidates(repositoryRoot) {
  if (!isOrchardRepositoryBaseRoot(repositoryRoot)) {
    return [];
  }
  return safeReadDirectory(repositoryRoot).filter((entry) => entry.isDirectory()).map((entry) => join(repositoryRoot, entry.name)).filter((entryPath) => isWorktreeDirectory(entryPath, repositoryRoot)).sort();
}
function isWorktreeDirectory(candidatePath, repositoryRoot) {
  const candidate = resolve(candidatePath);
  const root = resolve(repositoryRoot);
  const relativePath = relative(root, candidate);
  if (relativePath.length === 0 || relativePath.startsWith(`..${sep}`) || relativePath === ".." || relativePath.includes(sep)) {
    return false;
  }
  if (isReservedRepositoryEntry(basename(candidate))) {
    return false;
  }
  return isDirectory(candidate);
}
function isReservedRepositoryEntry(entryName) {
  return entryName === orchardLayout.gitDirectoryName || entryName === orchardLayout.symlinksDirectoryName || entryName === orchardLayout.bootstrapScriptName;
}
function isDirectory(path) {
  try {
    return existsSync(path) && statSync2(path).isDirectory();
  } catch {
    return false;
  }
}
function isFile(path) {
  try {
    return existsSync(path) && statSync2(path).isFile();
  } catch {
    return false;
  }
}
function safeReadDirectory(path) {
  try {
    return readdirSync(path, { withFileTypes: true });
  } catch {
    return [];
  }
}

// src/commands/worktree-args.ts
function parseWorktreeArgs(commandName, args) {
  let worktreeName2;
  for (let index = 0;index < args.length; index += 1) {
    const arg = args[index];
    if (arg === "--worktree") {
      const value = args[index + 1];
      if (!value) {
        throw new Error("--worktree requires a worktree name");
      }
      worktreeName2 = value;
      index += 1;
      continue;
    }
    throw new Error(`unknown ${commandName} flag: ${arg}`);
  }
  return { worktreeName: worktreeName2 };
}

