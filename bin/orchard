// src/lib/git.ts
import { realpathSync } from "node:fs";
import { basename as basename4, dirname as dirname2, join as join2, resolve as resolve2 } from "node:path";
async function runGit(args, options) {
  try {
    return await runProcess("git", args, { cwd: options.cwd });
  } catch (error) {
    return {
      stdout: "",
      stderr: `${error instanceof Error ? error.message : "git failed"}
`,
      exitCode: 1
    };
  }
}
async function requireGit(args, options, runner = runGit) {
  const result = await runner(args, options);
  if (result.exitCode !== 0) {
    throw new Error(result.stderr.trim() || `git ${args.join(" ")} failed`);
  }
  return result.stdout;
}
async function localBranchExists(repositoryRoot, branchName, runner = runGit) {
  const result = await runner(["show-ref", "--verify", "--quiet", `refs/heads/${branchName}`], { cwd: repositoryRoot });
  if (result.exitCode === 0) {
    return true;
  }
  if (result.exitCode === 1) {
    return false;
  }
  throw new Error(result.stderr.trim() || "git branch lookup failed");
}
async function gitWorktreePathExists(repositoryRoot, worktreeDirectory, runner = runGit) {
  const output = await requireGit(["worktree", "list", "--porcelain"], {
    cwd: repositoryRoot
  }, runner);
  const normalizedWorktreeDirectory = normalizePath(worktreeDirectory);
  return output.split(`
`).filter((line) => line.startsWith("worktree ")).some((line) => normalizePath(line.slice("worktree ".length)) === normalizedWorktreeDirectory);
}
function normalizePath(path) {
  const resolvedPath = resolve2(path);
  try {
    return realpathSync.native(resolvedPath);
  } catch {
    try {
      return join2(realpathSync.native(dirname2(resolvedPath)), basename4(resolvedPath));
    } catch {
      return resolvedPath.replace(/\/+$/, "");
    }
  }
}

// src/lib/symlink.ts
import {
  existsSync as existsSync2,
  lstatSync,
  mkdirSync,
  readdirSync as readdirSync2,
  readlinkSync,
  symlinkSync
} from "node:fs";
import { dirname as dirname3, join as join3, relative as relative2, resolve as resolve3 } from "node:path";
function createSymlinkPlan(symlinksDirectory, worktreePath2) {
  return listFiles(symlinksDirectory).map((sourcePath) => ({
    sourcePath,
    destinationPath: join3(worktreePath2, relative2(symlinksDirectory, sourcePath))
  }));
}
function applySymlinks(symlinksDirectory, worktreePath2) {
  const created = [];
  for (const { sourcePath, destinationPath } of createSymlinkPlan(symlinksDirectory, worktreePath2)) {
    if (pathExistsOrIsSymlink(destinationPath)) {
      validateExistingSymlink(destinationPath, sourcePath);
      continue;
    }
    mkdirSync(dirname3(destinationPath), { recursive: true });
    symlinkSync(sourcePath, destinationPath);
    created.push(destinationPath);
  }
  return { created };
}
function listFiles(directory) {
  const files = [];
  for (const entry of readdirSync2(directory, { withFileTypes: true })) {
    const entryPath = join3(directory, entry.name);
    if (entry.isDirectory()) {
      files.push(...listFiles(entryPath));
      continue;
    }
    if (entry.isFile()) {
      files.push(entryPath);
    }
  }
  return files.sort();
}
function pathExistsOrIsSymlink(path) {
  try {
    lstatSync(path);
    return true;
  } catch {
    return false;
  }
}
function validateExistingSymlink(destinationPath, expectedSourcePath) {
  const destinationStat = lstatSync(destinationPath);
  if (!destinationStat.isSymbolicLink()) {
    if (destinationStat.isDirectory()) {
      throw new Error(`destination is a real directory: ${destinationPath}`);
    }
    throw new Error(`destination is a real file: ${destinationPath}`);
  }
  const linkTarget = readlinkSync(destinationPath);
  const actualTarget = resolve3(dirname3(destinationPath), linkTarget);
  const expectedTarget = resolve3(expectedSourcePath);
  if (actualTarget !== expectedTarget) {
    if (!existsSync2(actualTarget)) {
      throw new Error(`destination is a broken symlink: ${destinationPath}`);
    }
    throw new Error(`destination symlink points elsewhere: ${destinationPath}`);
  }
}

// src/commands/clone.ts
var initialBootstrapScript = `#!/usr/bin/env bash
`;
async function runClone(args, options = {}) {
  try {
    const cloneArgs = parseCloneArgs(args);
    const remote = parseRemoteUrl(cloneArgs.repoUrl);
    const repositoryRoot = repositoryRootPath(remote, options.projectsRoot);
    const paths = orchardPaths(repositoryRoot);
    if (existsSync3(repositoryRoot)) {
      return fail(`target repository already exists: ${repositoryRoot}`);
    }
    const log = [];
    log.push(formatLog("info", `cloning ${remote.original}`));
    mkdirSync2(dirname4(repositoryRoot), { recursive: true });
    mkdirSync2(repositoryRoot);
    await requireGit(["clone", "--bare", remote.original, paths.gitDirectory], {
      cwd: repositoryRoot
    });
    mkdirSync2(paths.symlinksDirectory);
    writeFileSync(paths.bootstrapScript, initialBootstrapScript);
    chmodSync(paths.bootstrapScript, 493);
    const headBranch = (await requireGit(["symbolic-ref", "--short", "HEAD"], {
      cwd: paths.gitDirectory
    })).trim();
    const initialWorktreeName = worktreeName(remote.repoName, headBranch);
    const initialWorktreePath = worktreePath(repositoryRoot, remote.repoName, headBranch);
    await requireGit([
      "--git-dir",
      paths.gitDirectory,
      "worktree",
      "add",
      initialWorktreePath,
      headBranch
    ], { cwd: repositoryRoot });
    const symlinkResult = applySymlinks(paths.symlinksDirectory, initialWorktreePath);
    for (const createdPath of symlinkResult.created) {
      log.push(formatLog("success", `created symlink ${createdPath}`));
    }
    if (cloneArgs.bootstrap) {
      log.push(formatLog("info", `running bootstrap for ${initialWorktreeName}`));
      await runBootstrapScript(paths.bootstrapScript, initialWorktreePath);
    }
    log.push(formatLog("success", `created repository ${repositoryRoot}`));
    log.push(formatLog("success", `created worktree ${initialWorktreePath}`));
    return ok(log.join(""));
  } catch (error) {
    return fail(error instanceof Error ? error.message : "clone failed");
  }
}
function parseCloneArgs(args) {
  let repoUrl;
  let bootstrap = true;
  for (let index = 0;index < args.length; index += 1) {
    const arg = args[index];
    if (arg === "--repo") {
      const value = args[index + 1];
      if (!value) {
        throw new Error("--repo requires a remote URL");
      }
      repoUrl = value;
      index += 1;
      continue;
    }
    if (arg === "--no-bootstrap") {
      bootstrap = false;
      continue;
    }
    throw new Error(`unknown clone flag: ${arg}`);
  }
  if (!repoUrl) {
    throw new Error("orchard clone requires --repo <remote-url>");
  }
  return { repoUrl, bootstrap };
}

// src/commands/list.ts
function runList(args, options = {}) {
  const parsed = parseListArgs(args);
  const projectsRoot = options.projectsRoot ?? resolveProjectsRoot();
  const repositories = listOrchardRepositories(projectsRoot);
  const lines = parsed.mode === "repos" ? repositories : repositories.flatMap((repositoryRoot) => parsed.mode === "worktrees" ? listOrchardWorktrees(repositoryRoot) : [repositoryRoot, ...listOrchardWorktrees(repositoryRoot)]);
  if (lines.length === 0) {
    return ok("");
  }
  return ok(`${lines.join(`
`)}
`);
}
function parseListArgs(args) {
  const modes = [];
  for (const arg of args) {
    if (arg === "--repos") {
      modes.push("repos");
      continue;
    }
    if (arg === "--worktrees") {
      modes.push("worktrees");
      continue;
    }
    if (arg === "--all") {
      modes.push("all");
      continue;
    }
    return failParse(`unknown list flag: ${arg}`);
  }
  if (modes.length > 1) {
    return failParse("choose only one list mode");
  }
  return { mode: modes[0] ?? "all" };
}
function failParse(message) {
  throw new Error(message);
}

// src/commands/remove.ts
import { rmSync } from "node:fs";
import { basename as basename5 } from "node:path";
async function runRemove(args, options = {}) {
  try {
    const removeArgs = parseWorktreeArgs("remove", args);
    const cwd = options.cwd ?? process.cwd();
    const currentWorktree = findOrchardWorktree(cwd);
    const repositoryRoot = currentWorktree?.repositoryRoot ?? findOrchardRepositoryRoot(cwd);
    if (!repositoryRoot) {
      return fail("orchard remove must be run from inside an orchard repository");
    }
    const targetWorktreePath = await selectWorktreePath({
      commandName: "remove",
      currentWorktreePath: currentWorktree?.worktreePath,
      interactive: options.interactive ?? Boolean(process.stdin.isTTY && process.stdout.isTTY),
      requestedName: removeArgs.worktreeName,
      worktrees: listOrchardWorktrees(repositoryRoot)
    });
    const paths = orchardPaths(repositoryRoot);
    await requireGit([
      "--git-dir",
      paths.gitDirectory,
      "worktree",
      "remove",
      "--force",
      targetWorktreePath
    ], { cwd: repositoryRoot });
    rmSync(targetWorktreePath, { recursive: true, force: true });
    return ok(formatLog("success", `removed worktree ${basename5(targetWorktreePath)}`));
  } catch (error) {
    return fail(error instanceof Error ? error.message : "remove failed");
  }
}

// src/commands/symlink.ts
async function runSymlink(args, options = {}) {
  try {
    const symlinkArgs = parseWorktreeArgs("symlink", args);
    const cwd = options.cwd ?? process.cwd();
    const currentWorktree = findOrchardWorktree(cwd);
    const repositoryRoot = currentWorktree?.repositoryRoot ?? findOrchardRepositoryRoot(cwd);
    if (!repositoryRoot) {
      return fail("orchard symlink must be run from inside an orchard repository");
    }
    const worktreePath2 = await selectWorktreePath({
      commandName: "symlink",
      currentWorktreePath: currentWorktree?.worktreePath,
      interactive: options.interactive ?? Boolean(process.stdin.isTTY && process.stdout.isTTY),
      requestedName: symlinkArgs.worktreeName,
      worktrees: listOrchardWorktrees(repositoryRoot)
    });
    const paths = orchardPaths(repositoryRoot);
    const symlinkResult = applySymlinks(paths.symlinksDirectory, worktreePath2);
    const log = [];
    for (const createdPath of symlinkResult.created) {
      log.push(formatLog("success", `created symlink ${createdPath}`));
    }
    if (symlinkResult.created.length === 0) {
      log.push(formatLog("info", `symlinks already up to date for ${worktreePath2}`));
    }
    return ok(log.join(""));
  } catch (error) {
    return fail(error instanceof Error ? error.message : "symlink failed");
  }
}

// src/commands/tree.ts
import { basename as basename6 } from "node:path";
async function runTree(args, options = {}) {
  try {
    const treeArgs = parseTreeArgs(args);
    const cwd = options.cwd ?? process.cwd();
    const currentWorktree = findOrchardWorktree(cwd);
    if (!currentWorktree) {
      return fail("orchard tree must be run from inside an orchard worktree");
    }
    const repositoryRoot = currentWorktree.repositoryRoot;
    const paths = orchardPaths(repositoryRoot);
    const repoName = basename6(repositoryRoot);
    const branchName = branchNameForMode(treeArgs.mode);
    const targetWorktreeName = worktreeName(repoName, branchName);
    const targetWorktreePath = worktreePath(repositoryRoot, repoName, branchName);
    if (worktreeExists(repositoryRoot, repoName, branchName)) {
      return fail(`worktree already exists: ${targetWorktreePath}`);
    }
    if (await gitWorktreePathExists(paths.gitDirectory, targetWorktreePath)) {
      return fail(`worktree still registered in git: ${targetWorktreePath}. Run git -C ${paths.gitDirectory} worktree prune, or remove it with git -C ${paths.gitDirectory} worktree remove ${targetWorktreePath}`);
    }
    const gitArgs = await worktreeAddArgs({
      branchName,
      currentWorktreePath: currentWorktree.worktreePath,
      gitDirectory: paths.gitDirectory,
      mode: treeArgs.mode,
      sourceRef: treeArgs.from,
      targetWorktreePath
    });
    await requireGit(gitArgs, { cwd: repositoryRoot });
    const log = [];
    const symlinkResult = applySymlinks(paths.symlinksDirectory, targetWorktreePath);
    for (const createdPath of symlinkResult.created) {
      log.push(formatLog("success", `created symlink ${createdPath}`));
    }
    if (treeArgs.bootstrap) {
      log.push(formatLog("info", `running bootstrap for ${targetWorktreeName}`));
      await runBootstrapScript(paths.bootstrapScript, targetWorktreePath);
    }
    log.push(formatLog("success", `created worktree ${targetWorktreePath}`));
    return ok(log.join(""));
  } catch (error) {
    return fail(error instanceof Error ? error.message : "tree failed");
  }
}
async function worktreeAddArgs(options) {
  if (options.mode.type === "new") {
    if (await localBranchExists(options.gitDirectory, options.branchName)) {
      throw new Error(`local branch already exists: ${options.branchName}`);
    }
    return [
      "--git-dir",
      options.gitDirectory,
      "worktree",
      "add",
      "-b",
      options.branchName,
      options.targetWorktreePath,
      options.sourceRef ?? await currentBranchName(options.currentWorktreePath)
    ];
  }
  if (options.mode.type === "branch") {
    if (!await localBranchExists(options.gitDirectory, options.branchName)) {
      throw new Error(`local branch does not exist: ${options.branchName}`);
    }
    return [
      "--git-dir",
      options.gitDirectory,
      "worktree",
      "add",
      options.targetWorktreePath,
      options.branchName
    ];
  }
  if (await localBranchExists(options.gitDirectory, options.branchName)) {
    throw new Error(`local branch already exists: ${options.branchName}. Use orchard tree --branch ${options.branchName}`);
  }
  return [
    "--git-dir",
    options.gitDirectory,
    "worktree",
    "add",
    "-b",
    options.branchName,
    options.targetWorktreePath,
    await fetchRemoteBranch(options.gitDirectory, options.mode.remoteBranch)
  ];
}
function branchNameForMode(mode) {
  if (mode.type === "remote") {
    return parseRemoteBranch(mode.remoteBranch).branchName;
  }
  return mode.branchName;
}
function parseTreeArgs(args) {
  const parsed = { bootstrap: true };
  for (let index = 0;index < args.length; index += 1) {
    index = parseTreeArg(args, index, parsed);
  }
  if (!parsed.mode) {
    throw new Error(requiredTreeModeMessage());
  }
  if (parsed.from && parsed.mode.type !== "new") {
    throw new Error("--from can only be used with --new");
  }
  return {
    mode: parsed.mode,
    from: parsed.from,
    bootstrap: parsed.bootstrap
  };
}
function parseTreeArg(args, index, parsed) {
  const arg = args[index];
  if (arg === "--no-bootstrap") {
    parsed.bootstrap = false;
    return index;
  }
  if (arg === "--new") {
    parsed.mode = setTreeMode(parsed.mode, {
      type: "new",
      branchName: requiredArgValue(args, index, "--new", "a branch name")
    });
    return index + 1;
  }
  if (arg === "--branch") {
    parsed.mode = setTreeMode(parsed.mode, {
      type: "branch",
      branchName: requiredArgValue(args, index, "--branch", "a branch name")
    });
    return index + 1;
  }
  if (arg === "--remote") {
    const remoteBranch = requiredArgValue(args, index, "--remote", "a remote branch");
    parseRemoteBranch(remoteBranch);
    parsed.mode = setTreeMode(parsed.mode, { type: "remote", remoteBranch });
    return index + 1;
  }
  if (arg === "--from") {
    parsed.from = requiredArgValue(args, index, "--from", "a source ref");
    return index + 1;
  }
  throw new Error(`unknown tree flag: ${arg}`);
}
function requiredArgValue(args, index, flag, description) {
  const value = args[index + 1];
  if (!value) {
    throw new Error(`${flag} requires ${description}`);
  }
  return value;
}
function setTreeMode(currentMode, nextMode) {
  if (currentMode) {
    throw new Error(requiredTreeModeMessage());
  }
  return nextMode;
}
function requiredTreeModeMessage() {
  return "orchard tree requires exactly one of --new <branch>, --branch <branch>, or --remote <remote>/<branch>";
}
async function currentBranchName(worktreePath2) {
  const branchName = (await requireGit(["branch", "--show-current"], { cwd: worktreePath2 })).trim();
  if (branchName.length === 0) {
    throw new Error("current worktree is not on a branch");
  }
  return branchName;
}
async function fetchRemoteBranch(gitDirectory, remoteBranch) {
  const { branchName, remoteName } = parseRemoteBranch(remoteBranch);
  const remoteRef = `refs/remotes/${remoteName}/${branchName}`;
  await requireGit(["fetch", remoteName, `${branchName}:${remoteRef}`], {
    cwd: gitDirectory
  });
  return remoteRef;
}
function parseRemoteBranch(remoteBranch) {
  const slashIndex = remoteBranch.indexOf("/");
  if (slashIndex < 1 || slashIndex === remoteBranch.length - 1) {
    throw new Error("--remote requires a remote branch like origin/main");
  }
  return {
    remoteName: remoteBranch.slice(0, slashIndex),
    branchName: remoteBranch.slice(slashIndex + 1)
  };
}

// src/commands/registry.ts
var commandNames = [
  "clone",
  "list",
  "tree",
  "remove",
  "symlink",
  "bootstrap"
];
var commands = [
  {
    name: "clone",
    summary: "Clone a repository into the orchard layout.",
    usage: "orchard clone --repo <remote-url> [--no-bootstrap]",
    details: [
      "--repo <remote-url>  SSH or HTTPS Git remote to clone.",
      "--no-bootstrap      Skip running wt_bootstrap.sh for the initial worktree."
    ]
  },
  {
    name: "list",
    summary: "List orchard repositories and worktrees.",
    usage: "orchard list (--repos | --worktrees | --all)",
    details: [
      "--repos      Print repository root directories.",
      "--worktrees  Print worktree directories.",
      "--all        Print repositories and worktrees. Default when omitted."
    ]
  },
  {
    name: "tree",
    summary: "Create a new worktree in the current orchard repository.",
    usage: "orchard tree (--new <branch> [--from <ref>] | --branch <branch> | --remote <remote>/<branch>) [--no-bootstrap]",
    details: [
      "--new <branch>              Create a new local branch and worktree.",
      "--from <ref>                Source ref for --new. Defaults to the current branch.",
      "--branch <branch>           Create a worktree for an existing local branch.",
      "--remote <remote>/<branch>  Create a local branch and worktree from a remote branch.",
      "--no-bootstrap             Skip running wt_bootstrap.sh."
    ]
  },
  {
    name: "remove",
    summary: "Remove an orchard worktree.",
    usage: "orchard remove [--worktree <name>]",
    details: [
      "--worktree <name>  Worktree directory name to remove. The branch is left intact."
    ]
  },
  {
    name: "symlink",
    summary: "Apply repository symlinks to a worktree.",
    usage: "orchard symlink [--worktree <name>]",
    details: ["--worktree <name>  Worktree directory name to update."]
  },
  {
    name: "bootstrap",
    summary: "Run wt_bootstrap.sh for a worktree.",
    usage: "orchard bootstrap [--worktree <name>]",
    details: ["--worktree <name>  Worktree directory name to bootstrap."]
  }
];
function isCommandName(value) {
  return commandNames.includes(value);
}
function renderRootHelp() {
  const commandLines = commands.map((command) => `  ${command.name.padEnd(10)} ${command.summary}`).join(`
`);
  return `orchard

Usage:
  orchard <command> [flags]
  orchard -h | --help
  orchard -v | --version

Commands:
${commandLines}

Completion:
  orchard completion <bash|zsh>

Use "orchard <command> --help" for command-specific help.
`;
}
function renderCommandHelp(commandName) {
  const command = commands.find((candidate) => candidate.name === commandName);
  if (!command) {
    throw new Error(`missing command help for ${commandName}`);
  }
  const flags = command.details.map((detail) => `  ${detail}`).join(`
`);
  return `orchard ${command.name}

${command.summary}

Usage:
  ${command.usage}

Flags:
${flags}
  -h, --help  Show this help message.
`;
}
function dispatchCommand(commandName, args, options = {}) {
  if (args.includes("--help") || args.includes("-h")) {
    return ok(renderCommandHelp(commandName));
  }
  if (commandName === "clone") {
    return runClone(args, options);
  }
  if (commandName === "list") {
    try {
      return runList(args, options);
    } catch (error) {
      return fail(error instanceof Error ? error.message : "list failed");
    }
  }
  if (commandName === "tree") {
    return runTree(args, options);
  }
  if (commandName === "remove") {
    return runRemove(args, options);
  }
  if (commandName === "symlink") {
    return runSymlink(args, options);
  }
  if (commandName === "bootstrap") {
    return runBootstrap(args, options);
  }
  return fail(`orchard ${commandName} is not implemented yet`);
}

// src/commands/completion.ts
var completionWords = commandNames.join(" ");
function renderCompletion(args) {
  const shell = args[0];
  if (shell === "bash") {
    return ok(`_orchard_complete() {
  local current="\${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "${completionWords}" -- "$current"))
}
complete -F _orchard_complete orchard
`);
  }
  if (shell === "zsh") {
    return ok(`#compdef orchard
_arguments '1:command:(${completionWords})'
`);
  }
  return fail("usage: orchard completion <bash|zsh>");
}
// package.json
var package_default = {
  name: "orchard",
  version: "0.1.2",
  description: "A CLI for managing opinionated git worktree layouts.",
  type: "module",
  bin: {
    orchard: "./dist/orchard"
  },
  scripts: {
    test: "bun test",
    lint: "biome check .",
    format: "biome format --write .",
    build: "bun build src/main.ts --target=node --outfile=dist/orchard --banner='#!/usr/bin/env node' && chmod +x dist/orchard",
    fallow: "bunx fallow",
    check: "bun run lint && bun test && bun run build && bun run fallow"
  },
  dependencies: {
    "@clack/prompts": "latest",
    bombshell: "latest",
    chalk: "latest"
  },
  devDependencies: {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    fallow: "latest",
    typescript: "latest"
  },
  engines: {
    bun: ">=1.3.14",
    node: ">=22"
  }
};

// src/lib/version.ts
function resolveVersion() {
  const metadata = package_default;
  if (typeof metadata.version !== "string" || metadata.version.length === 0) {
    throw new Error("package.json must define a non-empty version");
  }
  return metadata.version;
}

// src/main.ts
async function run(args, options = {}) {
  const [firstArg, ...restArgs] = args;
  if (!firstArg || firstArg === "--help" || firstArg === "-h") {
    return ok(renderRootHelp());
  }
  if (firstArg === "--version" || firstArg === "-v") {
    return ok(`${resolveVersion()}
`);
  }
  if (firstArg === "completion") {
    return renderCompletion(restArgs);
  }
  if (isCommandName(firstArg)) {
    return await dispatchCommand(firstArg, restArgs, {
      cwd: options.cwd ?? process.cwd(),
      interactive: options.interactive,
      projectsRoot: options.projectsRoot
    });
  }
  return {
    stdout: "",
    stderr: `error: unknown command "${firstArg}"

${renderRootHelp()}`,
    exitCode: 1
  };
}
if (__require.main == __require.module) {
  const result = await run(process.argv.slice(2));
  if (result.stdout.length > 0) {
    process.stdout.write(result.stdout);
  }
  if (result.stderr.length > 0) {
    process.stderr.write(result.stderr);
  }
  process.exitCode = result.exitCode;
}
export {
  run
};
