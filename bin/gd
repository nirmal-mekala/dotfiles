#!/usr/bin/env bash

set -e

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <search_term>"
    exit 1
fi

SEARCH_TERM="$1"

if ! command -v gum > /dev/null 2>&1; then
    echo "Error: gum is not installed. Exiting."
    exit 1
fi

COMMIT=$(git log --oneline | gum choose | awk '{print $1}')

if [ -z "$COMMIT" ]; then
    exit 1
fi

git diff "$COMMIT" -G"$SEARCH_TERM" --name-only | nvim-qf
