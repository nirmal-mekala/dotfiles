[user]
  name = Nirmal Mekala
  email = ndmekala@icloud.com
[core]
	editor = nvim
[init]
	defaultBranch = main
[push]
	default = current
[pull]
  rebase = false
[includeIf "gitdir:~/code/clockwork/bitbucket/"]
  path = ~/ghq/bitbucket.org/clockworkers/.gitconfig
[includeIf "gitdir:~/ghq/bitbucket.org/clockworkers/"]
  path = ~/ghq/bitbucket.org/clockworkers/.gitconfig
[includeIf "gitdir:~/ghq/gitlab.tis.trane.com/"]
  path = ~/ghq/gitlab.tis.trane.com/.gitconfig
[includeIf "gitdir:~/projects/gitlab.tis.trane.com_denali_tranecloud/"]
  path = ~/projects/gitlab.tis.trane.com_denali_tranecloud/.gitconfig
[includeIf "gitdir:~/projects/bitbucket.org_clockworkers/"]
  path = ~/projects/bitbucket.org_clockworkers/.gitconfig
[diff]
	tool = nvimdiff
[difftool]
  prompt = false
[difftool "nvimdiff"]
  cmd = "nvim -d -c 'wincmd K' \"$LOCAL\" \"$REMOTE\""
